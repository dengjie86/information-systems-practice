    {
      "name": "3. 学生 - 报修流程",
      "item": [
        {
          "name": "POST /api/orders - 学生提交报修（保存 orderId）",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('提交成功', () => pm.expect(r.code).to.eql(200));",
                  "if (r.data && r.data.id) {",
                  "  pm.environment.set('orderId', String(r.data.id));",
                  "  console.log('orderId =', r.data.id, ' orderNo =', r.data.orderNo);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenStudent}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"宿舍灯不亮\",\n  \"categoryId\": {{categoryId}},\n  \"description\": \"进门处吸顶灯无法开启，已换过灯管仍然不亮\",\n  \"contactPhone\": \"13800000011\",\n  \"priority\": \"NORMAL\",\n  \"imageUrl\": \"\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "GET /api/orders/my - 学生查看自己的工单",
